---
interface Props {
  label: string;
  href: string;
  isActive?: boolean;
}

const { label, href, isActive } = Astro.props;
---

<li class="navbar__link-item">
  <a href={href} class:list={['navbar__link', { 'navbar__link--active': isActive }]}>
    {label}
  </a>
</li>

<style>
  .navbar__link-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
  }

  .navbar__link {
    font-family: 'Barlow Semi Condensed', sans-serif;
    font-weight: 700;
    font-size: 20px;
    line-height: 1;
    color: #000;
    text-decoration: none;
    white-space: nowrap;
    padding: 6px;
  }

  .navbar__link:hover,
  .navbar__link--active {
    background-color: transparent;
    background-color: #000;
    color: #fff;
  }

  @media (max-width: 768px) {
    .navbar__link-item {
      padding: 0;
      width: 100%;
      border-bottom: 1px solid #000;
    }

    .navbar__link {
      font-size: 20px;
      padding: 24px 8px;
      width: 100%;
      text-align: center;
    }
  }
</style>
