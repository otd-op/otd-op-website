---
interface Props {
  label: string;
  href: string;
  isActive?: boolean;
}

const { label, href, isActive } = Astro.props;
---

<li class="navbar__link-item">
  <a href={href} class:list={['navbar__link text-ui', { 'navbar__link--active': isActive }]}>
    {label}
  </a>
</li>

<style>
  .navbar__link-item {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .navbar__link {
    white-space: nowrap;
    padding: var(--space-1);
    text-decoration: none;
    color: var(--color-text-primary);
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  .navbar__link:hover,
  .navbar__link--active {
    background-color: var(--color-interactive-bg);
    color: var(--color-interactive-text);
  }

  @media (max-width: 768px) {
    .navbar__link-item {
      padding: 0;
      width: 100%;
      border-bottom: var(--border-width-thin) solid var(--color-border);
    }

    .navbar__link {
      padding: var(--space-6) var(--space-2);
      width: 100%;
      text-align: center;
    }
  }
</style>
