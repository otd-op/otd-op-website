---
import InstagramIcon from '../assets/instagram.svg';
import RssIcon from '../assets/rss.svg';
import { ROUTES } from '../config/routes';
import type { Locale } from '../i18n';
import { t } from '../i18n';

interface Props {
  class?: string;
  locale?: Locale;
}

const { class: className, locale = 'en' } = Astro.props;

const pathname = Astro.url.pathname;
const otherLocale = locale === 'en' ? 'fr' : 'en';
const otherLocaleUrl = pathname.replace(/^\/(en|fr)/, `/${otherLocale}`);
const otherLocaleLabel = otherLocale === 'en' ? 'EN' : 'FR';
---

<div class={className}>
  <a
    href={ROUTES.instagram}
    target="_blank"
    rel="noopener noreferrer"
    class="icon-btn"
    aria-label={t(locale, 'social.instagram')}
  >
    <InstagramIcon />
  </a>
  <a href={ROUTES.rss} class="icon-btn" aria-label={t(locale, 'social.rss')}>
    <RssIcon />
  </a>
  <a href={otherLocaleUrl} class="lang-toggle text-ui" aria-label={`Switch to ${otherLocaleLabel}`}>
    {otherLocaleLabel}
  </a>
</div>

<style>
  div {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--icon-size-sm);
    height: var(--icon-size-sm);
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    color: inherit;
  }

  .icon-btn :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .lang-toggle {
    white-space: nowrap;
    padding: var(--space-1);
    text-decoration: none;
    color: var(--color-text-primary);
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  .lang-toggle:hover {
    background-color: var(--color-interactive-bg);
    color: var(--color-interactive-text);
  }
</style>
