---
import type { Locale } from '../../i18n';
import { t } from '../../i18n';
import Layout from '../../layouts/Layout.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const downloadHeading = t(locale, 'documents.downloadHeading');
const downloadText = t(locale, 'documents.download');

const documents = [
  {
    name: t(locale, 'documents.list.0.name'),
    description: t(locale, 'documents.list.0.description'),
    file: t(locale, 'documents.list.0.file'),
  },
  {
    name: t(locale, 'documents.list.1.name'),
    description: t(locale, 'documents.list.1.description'),
    file: t(locale, 'documents.list.1.file'),
  },
  {
    name: t(locale, 'documents.list.2.name'),
    description: t(locale, 'documents.list.2.description'),
    file: t(locale, 'documents.list.2.file'),
  },
  {
    name: t(locale, 'documents.list.3.name'),
    description: t(locale, 'documents.list.3.description'),
    file: t(locale, 'documents.list.3.file'),
  },
  {
    name: t(locale, 'documents.list.4.name'),
    description: t(locale, 'documents.list.4.description'),
    file: t(locale, 'documents.list.4.file'),
  },
];
---

<Layout
  title={t(locale, 'documents.title')}
  description={t(locale, 'documents.description')}
  activeNav="documents"
>
  <main class="container">
    <div class="documents-container">
      <h2 class="documents-heading text-heading-1">{downloadHeading}</h2>

      <ul class="documents-list">
        {
          documents.map((doc, index) => (
            <li class="document-item">
              <div class="document-header">
                <span class="document-name text-body-medium">{doc.name}</span>
                <a href={doc.file} class="document-download text-body-medium" download>
                  {downloadText}
                </a>
              </div>
              <p class="document-description text-body">{doc.description}</p>
              {index < documents.length - 1 && <hr class="document-divider" />}
            </li>
          ))
        }
      </ul>
    </div>
  </main>
</Layout>

<style>
  .documents-container {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .documents-heading {
    margin: 0;
  }

  .documents-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .document-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .document-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .document-name {
    flex: 1;
    color: var(--color-text-primary);
  }

  .document-download {
    white-space: nowrap;
    text-decoration: underline;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: color var(--transition-fast);
  }

  .document-download:hover {
    color: var(--color-text-primary);
  }

  .document-description {
    margin: 0;
    color: var(--color-text-primary);
  }

  .document-divider {
    border: none;
    border-top: var(--border-width-thin) solid var(--color-border-light);
    margin-top: var(--space-4);
  }
</style>
