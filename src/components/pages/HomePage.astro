---
import ContentSection from '../../components/ContentSection.astro';
import InstagramEmbed from '../../components/InstagramEmbed.astro';
import type { Locale } from '../../i18n';
import { t } from '../../i18n';
import Layout from '../../layouts/Layout.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const sections = [
  {
    title: t(locale, 'home.sections.whoWeAre.title'),
    content: t(locale, 'home.sections.whoWeAre.content'),
  },
  {
    title: t(locale, 'home.sections.classStruggle.title'),
    content: t(locale, 'home.sections.classStruggle.content'),
  },
  {
    title: t(locale, 'home.sections.overcomingLocalism.title'),
    content: t(locale, 'home.sections.overcomingLocalism.content'),
  },
  {
    title: t(locale, 'home.sections.joinUs.title'),
    content: t(locale, 'home.sections.joinUs.content'),
    href: `/${locale}/join`,
  },
];
---

<Layout title={t(locale, 'home.title')} description={t(locale, 'home.description')}>
  <main class="home container">
    <!-- Content Sections -->
    {
      sections.map(section => (
        <ContentSection title={section.title} content={section.content} href={section.href} />
      ))
    }

    <!-- Instagram Embed -->
    <div class="home__instagram">
      <InstagramEmbed />
    </div>
  </main>
</Layout>

<style>
  .home {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .home__hero {
    width: 100%;
  }

  .placeholder {
    background-color: var(--color-gray-200);
    width: 100%;
  }

  .placeholder--hero {
    aspect-ratio: 16 / 9;
    min-height: 350px;
  }

  .home__instagram {
    width: 100%;
    overflow: hidden;
  }

  .home__instagram :global(blockquote) {
    margin: 0;
    width: 100% !important;
  }

  :global(.link-title) {
    text-decoration: underline;
    color: inherit;
  }
</style>
