---
import Layout from '../../layouts/Layout.astro';
import type { Locale } from '../../i18n';
import { t } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<Layout
  title={t(locale, 'join.title')}
  description={t(locale, 'join.description')}
  activeNav="join"
>
  <main class="container">
    <h1>{t(locale, 'join.heading')}</h1>
    <p>{t(locale, 'join.message')}</p>
    <p>{t(locale, 'join.contactPrefix')} <strong><u>{t(locale, 'join.email')}</u></strong></p>
    <p>
      {t(locale, 'join.protonText')}
      <strong
        ><u><a href="https://proton.me" target="_blank" rel="noopener noreferrer">ProtonMail</a></u
        ></strong
      >.
    </p>
  </main>
</Layout>
