---
import type { Locale } from '../../i18n';
import { t } from '../../i18n';
import Layout from '../../layouts/Layout.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<Layout
  title={t(locale, 'join.title')}
  description={t(locale, 'join.description')}
  activeNav="join"
>
  <main class="container">
    <h1 class="text-heading-1">{t(locale, 'join.heading')}</h1>
    <div>
      <p>{t(locale, 'join.message')}</p>
      <p>{t(locale, 'join.contactPrefix')} <strong><u>{t(locale, 'join.email')}</u></strong></p>
      <p>
        {t(locale, 'join.protonText')}
        <strong
          ><u
            ><a href="https://proton.me" target="_blank" rel="noopener noreferrer">ProtonMail</a></u
          ></strong
        >.
      </p>
    </div>
  </main>
</Layout>

<style>
  .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
</style>
