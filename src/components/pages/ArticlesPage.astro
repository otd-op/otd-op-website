---
import type { Locale } from '../../i18n';
import { t } from '../../i18n';
import Layout from '../../layouts/Layout.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<Layout
  title={t(locale, 'articles.title')}
  description={t(locale, 'articles.description')}
  activeNav="articles"
>
  <main class="container">
    <h2 class="text-heading-1">{t(locale, 'articles.heading')}</h2>
    <p>{t(locale, 'articles.message')}</p>
  </main>
</Layout>

<style>
  .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
</style>
