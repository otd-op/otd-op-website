---
import type { Locale } from '../../i18n';
import { t } from '../../i18n';
import Layout from '../../layouts/Layout.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<Layout
  title={t(locale, 'about.title')}
  description={t(locale, 'about.description')}
  activeNav="about"
>
  <main class="container">
    <section class="hero">
      <h1 class="hero-line text-heading-1">{t(locale, 'about.hero')}</h1>
    </section>

    <section class="intro">
      <p class="text-body" set:html={t(locale, 'about.intro.paragraph1')} />
      <p class="text-body">{t(locale, 'about.intro.paragraph2')}</p>
    </section>

    <section class="class-struggle">
      <h2 class="text-heading-2">{t(locale, 'about.classStruggle.heading')}</h2>
      <p class="text-body" set:html={t(locale, 'about.classStruggle.paragraph1')} />
      <p class="text-body">{t(locale, 'about.classStruggle.paragraph2')}</p>
    </section>

    <section class="localism">
      <h2 class="text-heading-2">{t(locale, 'about.localism.heading')}</h2>
      <p class="text-body">{t(locale, 'about.localism.paragraph1')}</p>
      <p class="text-body" set:html={t(locale, 'about.localism.paragraph2')} />
      <p class="text-body" set:html={t(locale, 'about.localism.paragraph3')} />
    </section>

    <section class="overcoming">
      <h2 class="text-heading-2">{t(locale, 'about.overcoming.heading')}</h2>
      <p class="text-body">{t(locale, 'about.overcoming.paragraph1')}</p>
      <p class="text-body">{t(locale, 'about.overcoming.paragraph2')}</p>
      <p class="text-body">{t(locale, 'about.overcoming.paragraph3')}</p>
    </section>

    <section class="socialism">
      <h2 class="text-heading-2">{t(locale, 'about.socialism.heading')}</h2>
      <p class="text-body" set:html={t(locale, 'about.socialism.paragraph1')} />
      <p class="text-body">{t(locale, 'about.socialism.paragraph2')}</p>
    </section>

    <section class="struggle">
      <h2 class="text-heading-2">{t(locale, 'about.struggle.heading')}</h2>
      <p class="text-body">{t(locale, 'about.struggle.paragraph1')}</p>
      <p class="text-body">{t(locale, 'about.struggle.paragraph2')}</p>
      <p class="text-body">{t(locale, 'about.struggle.paragraph3')}</p>
    </section>
  </main>
</Layout>

<style>
  .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  section {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .hero {
    gap: 0;
  }

  :global(strong) {
    font-weight: 700;
  }

  :global(em) {
    font-style: italic;
  }
</style>
