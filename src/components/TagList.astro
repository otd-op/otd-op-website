---
import { getPublishedPosts, getAllTags } from '../../../utils/content';
import { ROUTES } from '../../../config/routes';

const posts = await getPublishedPosts();
const tagCounts = getAllTags(posts);

const entries: Array<[string, number]> = Array.from(tagCounts.entries());
const sortedTags = entries.sort((a, b) => b[1] - a[1]);
---

{
  sortedTags.length > 0 && (
    <div>
      <h3>Tags</h3>
      <ul>
        {sortedTags.map(entry => {
          const tag = entry[0];
          const count = entry[1];
          return (
            <li>
              <a href={ROUTES.tag(tag)}>
                {tag} ({count})
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  )
}
