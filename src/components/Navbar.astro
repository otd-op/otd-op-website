---
import type { NavItem } from '../types/navigation';
import { getLocaleFromPath, t } from '../i18n';

interface Props {
  activeItem?: NavItem;
}

const { activeItem } = Astro.props;

const pathname = Astro.url.pathname;
const locale = getLocaleFromPath(pathname);

const navItems = [
  { label: t(locale, 'nav.articles'), href: `/${locale}/articles`, id: 'articles' },
  { label: t(locale, 'nav.documents'), href: `/${locale}/documents`, id: 'documents' },
  { label: t(locale, 'nav.about'), href: `/${locale}/about`, id: 'about' },
  { label: t(locale, 'nav.join'), href: `/${locale}/join`, id: 'join' },
];

import LogoOTD from '../assets/logo-otd.svg';
import LogoOP from '../assets/logo-op.svg';
import Divider from '../assets/divider.svg';
import NavItemComponent from './NavItem.astro';
import Icons from './Icons.astro';
---

<nav class="navbar">
  <div class="navbar__container">
    <div class="navbar__logo">
      <a href={`/${locale}`} aria-label={t(locale, 'aria.home')}>
        {locale === 'en' ? <LogoOTD /> : <LogoOP />}
      </a>
    </div>

    <ul class="navbar__links">
      {
        navItems.map(item => (
          <NavItemComponent label={item.label} href={item.href} isActive={activeItem === item.id} />
        ))
      }
      <li class="navbar__mobile-actions">
        <Icons locale={locale} />
      </li>
    </ul>

    <div class="navbar__actions">
      <Icons locale={locale} />
    </div>

    <button
      class="navbar__menu-toggle"
      aria-label={t(locale, 'aria.toggleMenu')}
      aria-expanded="false"
    >
      <span class="navbar__menu-bar"></span>
      <span class="navbar__menu-bar"></span>
      <span class="navbar__menu-bar"></span>
      <span class="navbar__menu-close">✕</span>
    </button>
  </div>

  <div class="navbar__divider">
    <Divider />
  </div>
</nav>

<script>
  const menuToggle = document.querySelector('.navbar__menu-toggle');
  const navbarLinks = document.querySelector('.navbar__links');

  menuToggle?.addEventListener('click', () => {
    const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
    menuToggle.setAttribute('aria-expanded', String(!isExpanded));
    navbarLinks?.classList.toggle('navbar__links--open');
  });
</script>

<style>
  .navbar {
    width: 100%;
    background-color: var(--color-background-primary);
    position: relative;
    z-index: var(--z-sticky);
  }

  .navbar__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--navbar-padding-desktop);
    margin: 0 auto;
    position: relative;
  }

  .navbar__logo {
    width: var(--navbar-logo-width);
    height: var(--navbar-logo-height);
    flex-shrink: 0;
  }

  .navbar__links {
    display: flex;
    align-items: center;
    justify-content: space-between;
    list-style: none;
    margin: 0;
    padding: 0;
    width: var(--navbar-links-width-desktop);
    flex-shrink: 0;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .navbar__actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .navbar__actions :global(.icon-btn) {
    width: var(--icon-size-sm);
    height: var(--icon-size-sm);
  }

  .navbar__mobile-actions {
    display: none;
    list-style: none;
  }

  .navbar__mobile-actions :global(div) {
    gap: var(--space-6);
  }

  .navbar__mobile-actions :global(.icon-btn) {
    width: var(--icon-size-lg);
    height: var(--icon-size-lg);
  }

  .navbar__menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: var(--icon-size-sm);
    height: 18px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    position: relative;
  }

  .navbar__menu-bar {
    display: block;
    width: 100%;
    height: var(--border-width-thick);
    background-color: var(--color-border);
  }

  .navbar__menu-close {
    display: none;
    font-size: var(--font-size-xl);
    line-height: var(--line-height-none);
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .navbar__divider {
    width: 100%;
    height: 3px;
    line-height: 0;
  }

  .navbar__divider :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Tablet breakpoint */
  @media (max-width: 1024px) {
    .navbar__container {
      padding: var(--navbar-padding-tablet);
    }

    .navbar__links {
      width: var(--navbar-links-width-tablet);
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }
  }

  /* Mobile breakpoint */
  @media (max-width: 768px) {
    .navbar__container {
      padding: var(--navbar-padding-mobile);
    }

    .navbar__links {
      display: none;
      position: fixed;
      top: var(--navbar-height-mobile);
      left: 0;
      width: 100%;
      height: calc(100vh - var(--navbar-height-mobile) - var(--space-2));
      flex-direction: column;
      justify-content: start;
      align-items: center;
      background-color: var(--color-overlay-light);
      margin: 0;
      padding: 0;
      z-index: var(--z-dropdown);
      transform: none;
    }

    .navbar__links--open {
      display: flex;
    }

    .navbar__actions {
      display: none;
    }

    .navbar__mobile-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-6) 0;
      width: 100%;
      border-bottom: var(--border-width-thin) solid var(--color-border);
    }

    .navbar__menu-toggle {
      display: flex;
    }

    .navbar__menu-toggle[aria-expanded='true'] .navbar__menu-bar {
      display: none;
    }

    .navbar__menu-toggle[aria-expanded='true'] .navbar__menu-close {
      display: block;
    }
  }
</style>
