---
interface Props {
  activeItem?: 'about' | 'articles' | 'documents' | 'join';
}

const { activeItem } = Astro.props;

const navItems = [
  { label: 'ABOUT', href: '/about', id: 'about' },
  { label: 'ARTICLES', href: '/articles', id: 'articles' },
  { label: 'DOCUMENTS', href: '/documents', id: 'documents' },
  { label: 'JOIN!', href: '/join', id: 'join' },
];

import Logo from '../assets/logo.svg';
import InstagramIcon from '../assets/instagram.svg';
import RssIcon from '../assets/rss.svg';
import Divider from '../assets/divider.svg';
import NavItem from './NavItem.astro';
---

<nav class="navbar">
  <div class="navbar__container">
    <div class="navbar__logo">
      <a href="/" aria-label="Home">
        <Logo />
      </a>
    </div>

    <ul class="navbar__links">
      {
        navItems.map(item => (
          <NavItem label={item.label} href={item.href} isActive={activeItem === item.id} />
        ))
      }
      <li class="navbar__mobile-actions">
        <a
          href="https://www.instagram.com/otd.op/"
          target="_blank"
          rel="noopener noreferrer"
          class="navbar__icon-btn"
          aria-label="Instagram"
        >
          <InstagramIcon />
        </a>
        <a href="/rss.xml" class="navbar__icon-btn" aria-label="RSS Feed">
          <RssIcon />
        </a>
      </li>
    </ul>

    <div class="navbar__actions">
      <a
        href="https://www.instagram.com/otd.op/"
        target="_blank"
        rel="noopener noreferrer"
        class="navbar__icon-btn"
        aria-label="Instagram"
      >
        <InstagramIcon />
      </a>
      <a href="/rss.xml" class="navbar__icon-btn" aria-label="RSS Feed">
        <RssIcon />
      </a>
    </div>

    <button class="navbar__menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="navbar__menu-bar"></span>
      <span class="navbar__menu-bar"></span>
      <span class="navbar__menu-bar"></span>
      <span class="navbar__menu-close">✕</span>
    </button>
  </div>

  <div class="navbar__divider">
    <Divider />
  </div>
</nav>

<script>
  const menuToggle = document.querySelector('.navbar__menu-toggle');
  const navbarLinks = document.querySelector('.navbar__links');

  menuToggle?.addEventListener('click', () => {
    const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
    menuToggle.setAttribute('aria-expanded', String(!isExpanded));
    navbarLinks?.classList.toggle('navbar__links--open');
  });
</script>

<style>
  .navbar {
    width: 100%;
    background-color: #fff;
    position: relative;
    z-index: 101;
  }

  .navbar__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 64px;
    margin: 0 auto;
  }

  .navbar__logo {
    width: 100px;
    height: 61px;
    flex-shrink: 0;
  }

  .navbar__logo :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .navbar__links {
    display: flex;
    align-items: center;
    justify-content: space-between;
    list-style: none;
    margin: 0;
    padding: 0;
    width: 640px;
    flex-shrink: 0;
  }

  .navbar__actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  .navbar__icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    color: inherit;
  }

  .navbar__icon-btn :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .navbar__mobile-actions {
    display: none;
    list-style: none;
  }

  .navbar__menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 18px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    position: relative;
  }

  .navbar__menu-bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: #000;
  }

  .navbar__menu-close {
    display: none;
    font-size: 24px;
    line-height: 1;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .navbar__divider {
    width: 100%;
    height: 3px;
    line-height: 0;
  }

  .navbar__divider :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Tablet breakpoint */
  @media (max-width: 1024px) {
    .navbar__container {
      padding: 24px 32px;
    }

    .navbar__links {
      width: 480px;
    }
  }

  /* Mobile breakpoint */
  @media (max-width: 768px) {
    .navbar__container {
      padding: 16px 24px;
    }

    .navbar__links {
      display: none;
      position: fixed;
      top: 96px;
      left: 0;
      width: 100%;
      height: calc(100vh - 109px);
      flex-direction: column;
      justify-content: start;
      align-items: center;
      background-color: rgba(255, 255, 255, 0.8);
      margin: 0;
      padding: 0;
      z-index: 100;
    }

    .navbar__links--open {
      display: flex;
    }

    .navbar__actions {
      display: none;
    }

    .navbar__mobile-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 24px;
      padding: 24px 0;
      width: 100%;
      border-bottom: 1px solid #000;
    }

    .navbar__mobile-actions .navbar__icon-btn {
      width: 32px;
      height: 32px;
    }

    .navbar__menu-toggle {
      display: flex;
    }

    .navbar__menu-toggle[aria-expanded='true'] .navbar__menu-bar {
      display: none;
    }

    .navbar__menu-toggle[aria-expanded='true'] .navbar__menu-close {
      display: block;
    }
  }
</style>
