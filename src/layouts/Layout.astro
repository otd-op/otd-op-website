---
import Navbar from '../components/Navbar.astro';
import type { NavItem } from '../types/navigation';
import { getLocaleFromPath } from '../i18n';

interface Props {
  title: string;
  description?: string;
  activeNav?: NavItem;
}

const { title, description, activeNav } = Astro.props;

const pathname = Astro.url.pathname;
const locale = getLocaleFromPath(pathname);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Semi+Condensed:wght@700&family=Special+Gothic&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <Navbar activeItem={activeNav} />
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    -moz-text-size-adjust: none;
    -webkit-text-size-adjust: none;
    text-size-adjust: none;
  }

  body {
    min-height: 100vh;
    line-height: 1.5;
    font-family:
      'Special Gothic',
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      'Segoe UI',
      Roboto,
      sans-serif;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: 'Barlow Semi Condensed', system-ui, sans-serif;
    font-weight: 700;
    overflow-wrap: break-word;
  }

  p {
    overflow-wrap: break-word;
  }

  ul,
  ol {
    list-style: none;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  button {
    font: inherit;
    background: none;
    border: none;
    cursor: pointer;
  }

  img,
  picture,
  video,
  canvas,
  svg {
    display: block;
    max-width: 100%;
  }

  input,
  textarea,
  select {
    font: inherit;
  }

  .container {
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
    padding: 32px 0;
  }

  @media (max-width: 768px) {
    .container {
      max-width: 320px;
      padding: 24px 16px;
    }
  }
</style>
