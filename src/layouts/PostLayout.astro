---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../utils/date';
import TagLinks from '../components/TagLinks.astro';
import type { Locale } from '../i18n';

interface Props {
  post: CollectionEntry<'blog'>;
  locale: Locale;
}

const { post, locale } = Astro.props;
const { title, description, pubDate, updatedDate, author, tags } = post.data;

const formattedDate = formatDate(pubDate, 'long');
const formattedUpdated = updatedDate ? formatDate(updatedDate, 'long') : undefined;
---

<Layout title={title} description={description} activeNav="articles">
  <article>
    <header>
      <h1>{title}</h1>
      <p>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {formattedUpdated && <span>(updated {formattedUpdated})</span>}
        <span>by {author}</span>
      </p>
      <TagLinks tags={tags} locale={locale} />
    </header>

    <div>
      <slot />
    </div>
  </article>
</Layout>
