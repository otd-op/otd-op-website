---
import Layout from '../../../../layouts/Layout.astro';
import PostCard from '../../../../components/PostCard.astro';
import { getPublishedPosts, sortPostsByDate, extractUniqueTags } from '../../../../utils/content';
import { ROUTES } from '../../../../config/routes';
import { t } from '../../../../i18n';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = extractUniqueTags(posts);

  return Array.from(tags).map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: sortPostsByDate(posts.filter(post => post.data.tags.includes(tag))),
    },
  }));
}

const { tag, posts } = Astro.props;

const title = t('fr', 'tag.title').replace('{tag}', tag);
const description = `Tous les articles tagués avec ${tag}`;
---

<Layout title={title} description={description} activeNav="articles">
  <h1>{t('fr', 'tag.title').replace('{tag}', tag)}</h1>
  <p><a href={ROUTES.articles('fr')}>{t('fr', 'tag.allPosts')}</a></p>

  {posts.map(post => <PostCard post={post} locale="fr" />)}
</Layout>
