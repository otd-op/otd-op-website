---
import Layout from '../layouts/Layout.astro';
import InstagramEmbed from '../components/InstagramEmbed.astro';
import ContentSection from '../components/ContentSection.astro';

const sections = [
  { title: 'OFF THE DEFENSIVE', content: 'lorem ipsum' },
  { title: 'OFF THE DEFENSIVE', content: 'lorem ipsum' },
  { title: 'OFF THE DEFENSIVE', content: 'lorem ipsum' },
  { title: 'OFF THE DEFENSIVE', content: 'lorem ipsum' },
  { title: 'OFF THE DEFENSIVE', content: 'lorem ipsum' },
  { title: 'OFF THE DEFENSIVE', content: 'lorem ipsum' },
];
---

<Layout title="Home" description="Welcome to Off The Defensive">
  <main class="home container">
    <!-- Hero Placeholder -->
    <div class="home__hero">
      <div class="placeholder placeholder--hero"></div>
    </div>

    <!-- Content Sections -->
    {sections.map(section => <ContentSection title={section.title} content={section.content} />)}

    <!-- Instagram Embed -->
    <div class="home__instagram">
      <InstagramEmbed />
    </div>
  </main>
</Layout>

<style>
  .home {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .home__hero {
    width: 100%;
  }

  .placeholder {
    background-color: #e8e8e8;
    width: 100%;
  }

  .placeholder--hero {
    aspect-ratio: 16 / 9;
    min-height: 350px;
  }

  .home__instagram {
    width: 100%;
  }

  .home__instagram :global(blockquote) {
    margin: 0;
    width: 100% !important;
  }
</style>
