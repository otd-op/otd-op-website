---
import Layout from '../layouts/Layout.astro';
import InstagramEmbed from '../components/InstagramEmbed.astro';
---

<Layout title="Home" description="Welcome to Off The Defensive">
  <main class="home container">
      <!-- Hero Placeholder -->
      <div class="home__hero">
        <div class="placeholder placeholder--hero"></div>
      </div>

      <!-- Content Sections -->
      <section class="home__section">
        <h2>OFF THE DEFENSIVE</h2>
        <p>lorem ipsum</p>
      </section>

      <section class="home__section">
        <h2>OFF THE DEFENSIVE</h2>
        <p>lorem ipsum</p>
      </section>

      <section class="home__section">
        <h2>OFF THE DEFENSIVE</h2>
        <p>lorem ipsum</p>
      </section>

      <section class="home__section">
        <h2>OFF THE DEFENSIVE</h2>
        <p>lorem ipsum</p>
      </section>

      <section class="home__section">
        <h2>OFF THE DEFENSIVE</h2>
        <p>lorem ipsum</p>
      </section>

      <section class="home__section">
        <h2>OFF THE DEFENSIVE</h2>
        <p>lorem ipsum</p>
      </section>

      <!-- Instagram Embed -->
      <div class="home__instagram">
        <InstagramEmbed />
      </div>
  </main>
</Layout>

<style>
  .home {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .home__hero {
    width: 100%;
  }

  .placeholder {
    background-color: #e8e8e8;
    width: 100%;
  }

  .placeholder--hero {
    aspect-ratio: 16 / 9;
    min-height: 350px;
  }

  .home__section {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .home__section h2 {
    font-size: 18px;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .home__instagram {
    width: 100%;
  }

  .home__instagram :global(blockquote) {
    margin: 0;
    width: 100% !important;
  }
</style>
