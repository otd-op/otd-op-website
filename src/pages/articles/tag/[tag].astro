---
import Layout from '../../../layouts/Layout.astro';
import PostCard from '../../../components/PostCard.astro';
import { getPublishedPosts, sortPostsByDate, extractUniqueTags } from '../../../utils/content';
import { ROUTES } from '../../../config/routes';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = extractUniqueTags(posts);

  return Array.from(tags).map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: sortPostsByDate(posts.filter(post => post.data.tags.includes(tag))),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<Layout
  title={`Posts tagged #${tag}`}
  description={`All posts tagged with ${tag}`}
  activeNav="articles"
>
  <h1>Posts tagged #{tag}</h1>
  <p><a href={ROUTES.articles}>← All posts</a></p>

  {posts.map(post => <PostCard post={post} />)}
</Layout>
